---
// Footer
---

<footer
  class="bg-surface-low"
  style="border-top: 1px solid rgba(208,197,175,0.08);"
>
  <!-- Main footer row -->
  <div
    class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-8"
  >
    <!-- Wordmark + tagline -->
    <div class="flex flex-col gap-3">
      <a href="/" class="flex items-center gap-1 no-underline">
        <img src="/app-icon.png" alt="Open Citadel logo" class="h-12 w-12" />
        <span
          class="font-display text-gold text-base font-medium tracking-tight leading-none"
        >
          Open Citadel
        </span>
      </a>
      <p
        class="font-body text-xs text-parchment-dim m-0 leading-relaxed max-w-xs"
      >
        Your knowledge companion <br /> Open source. Privacy first.
      </p>
    </div>

    <!-- Nav links -->
    <nav aria-label="Footer navigation">
      <ul class="list-none m-0 p-0 flex flex-col sm:flex-row gap-5 sm:gap-8">
        {
          [
            {
              label: "GitHub",
              href: "https://github.com/dr-33-m/open-citadel",
              external: true,
            },
            {
              label: "Contact",
              href: "mailto:thamsanqa.dev@gmail.com",
              external: false,
            },
          ].map(({ label, href, external }) => (
            <li>
              <a
                href={href}
                target={external ? "_blank" : undefined}
                rel={external ? "noopener noreferrer" : undefined}
                class="font-body text-sm text-parchment-dim hover:text-gold transition-colors no-underline uppercase tracking-[0.08em]"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <!-- Bottom bar -->
  <div
    class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-5 flex items-center justify-between"
    style="border-top: 1px solid rgba(208,197,175,0.06);"
  >
    <p class="font-body text-xs text-parchment-dim m-0" style="opacity: 0.5;">
      &copy; 2025 Open Citadel. Open Source Software.
    </p>
  </div>
</footer>
