---
// CrossPlatform — "Open Source & Cross-Platform"
---

<section
  id="download"
  class="py-28 md:py-36 px-6 md:px-12 lg:px-20 bg-surface-low"
>
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
    <!-- Left: copy -->
    <div>
      <p
        class="font-body text-xs font-semibold text-gold uppercase tracking-[0.12em] mb-5 m-0"
      >
        Available Now
      </p>
      <h2
        class="font-display text-parchment m-0 mb-6"
        style="font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 400; line-height: 1.15;"
      >
        Open Source &amp;<br />Cross-Platform
      </h2>
      <p
        class="font-body text-parchment-dim text-base leading-relaxed m-0 max-w-sm"
      >
        Built in the open. Every line of code is available to inspect, fork, and
        build on. Android is live — iOS is on the way.
      </p>
    </div>

    <!-- Right: store badges -->
    <div id="waitlist" class="flex flex-col gap-5">
      <!-- Android (active) -->
      <a
        href="https://cloudreve.cr8-xyz.art/s/bdTk"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 px-6 py-4 no-underline group transition-opacity hover:opacity-90"
        style="background: linear-gradient(135deg, #f2ca50, #d4af37);"
        aria-label="Download Open Citadel for Android"
      >
        <!-- Android brand icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          preserveAspectRatio="xMidYMid"
          viewBox="0 0 256 150"
          width="28"
          height="28"
          aria-hidden="true"
          ><path
            fill="#131313"
            d="M255.285 143.47c-.084-.524-.164-1.042-.251-1.56a128.119 128.119 0 0 0-12.794-38.288 128.778 128.778 0 0 0-23.45-31.86 129.166 129.166 0 0 0-22.713-18.005c.049-.08.09-.168.14-.25 2.582-4.461 5.172-8.917 7.755-13.38l7.576-13.068c1.818-3.126 3.632-6.26 5.438-9.386a11.776 11.776 0 0 0 .662-10.484 11.668 11.668 0 0 0-4.823-5.536 11.85 11.85 0 0 0-5.004-1.61 11.963 11.963 0 0 0-2.218.018 11.738 11.738 0 0 0-8.968 5.798c-1.814 3.127-3.628 6.26-5.438 9.386l-7.576 13.069c-2.583 4.462-5.173 8.918-7.755 13.38-.282.487-.567.973-.848 1.467-.392-.157-.78-.313-1.172-.462-14.24-5.43-29.688-8.4-45.836-8.4-.442 0-.879 0-1.324.006-14.357.143-28.152 2.64-41.022 7.12a119.434 119.434 0 0 0-4.42 1.642c-.262-.455-.532-.911-.79-1.367-2.583-4.462-5.173-8.918-7.755-13.38L65.123 15.25c-1.818-3.126-3.632-6.259-5.439-9.386A11.736 11.736 0 0 0 48.5.048 11.71 11.71 0 0 0 43.49 1.66a11.716 11.716 0 0 0-4.077 4.063c-.281.474-.532.967-.742 1.473a11.808 11.808 0 0 0-.365 8.188c.259.786.594 1.554 1.023 2.296a3973.32 3973.32 0 0 1 5.439 9.386c2.53 4.357 5.054 8.713 7.58 13.069 2.582 4.462 5.168 8.918 7.75 13.38.02.038.046.075.065.112A129.184 129.184 0 0 0 45.32 64.38a129.693 129.693 0 0 0-22.2 24.015 127.737 127.737 0 0 0-9.34 15.24 128.238 128.238 0 0 0-10.843 28.764 130.743 130.743 0 0 0-1.951 9.524c-.087.518-.167 1.042-.247 1.56A124.978 124.978 0 0 0 0 149.118h256c-.205-1.891-.449-3.77-.734-5.636l.019-.012Z"
          ></path></svg
        >
        <div>
          <p
            class="font-display text-xs font-medium text-ink uppercase tracking-[0.08em] m-0"
          >
            Download
          </p>
          <p class="font-display text-lg font-bold text-ink m-0 leading-tight">
            Open Citadel
          </p>
        </div>
        <span
          class="ml-auto font-display text-xs font-semibold text-ink uppercase tracking-[0.1em] px-2.5 py-1"
          style="background: rgba(19,19,19,0.15);"
        >
          Available now
        </span>
      </a>

      <!-- iOS (coming soon, disabled style) -->
      <div
        class="flex items-center gap-4 px-6 py-4 opacity-40 cursor-not-allowed bg-surface-low"
        aria-label="iOS App Store — coming soon"
      >
        <!-- Apple brand icon -->
        <svg
          xml:space="preserve"
          viewBox="0 0 814 1000"
          width="28"
          height="28"
          aria-hidden="true"
          ><path
            fill="currentColor"
            d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
          ></path></svg
        >
        <div>
          <p
            class="font-body text-xs font-medium text-parchment uppercase tracking-[0.08em] m-0"
          >
            Download on the
          </p>
          <p
            class="font-body text-lg font-bold text-parchment m-0 leading-tight"
          >
            App Store
          </p>
        </div>
        <span
          class="ml-auto font-body text-xs text-parchment-dim uppercase tracking-[0.1em]"
        >
          Coming Soon
        </span>
      </div>

      <!-- Source link -->
      <a
        href="https://github.com/dr-33-m/open-citadel"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 font-body text-sm text-parchment-dim hover:text-gold transition-colors no-underline mt-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="square"
          aria-hidden="true"
        >
          <path
            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
          ></path>
        </svg>
        View source on GitHub
      </a>
    </div>
  </div>
</section>
