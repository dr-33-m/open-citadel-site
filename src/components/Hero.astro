---
// Hero — editorial two-column layout
import library1Light from "../assets/screenshots/light/library-1-light.png";
import library1Dark from "../assets/screenshots/dark/library1-dark.png";
---

<section
  id="hero"
  class="relative min-h-screen flex items-center pt-24 pb-20 px-6 md:px-12 lg:px-20 bg-obsidian overflow-hidden"
>
  <!-- Background texture: subtle radial glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(242,202,80,0.04) 0%, transparent 70%);"
  >
  </div>

  <div
    class="relative z-10 w-full max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center"
  >
    <!-- Left: Copy -->
    <div class="flex flex-col gap-8">
      <!-- Eyebrow -->
      <p
        class="font-body text-xs font-semibold text-gold uppercase tracking-[0.12em] m-0"
      >
        Open Source &nbsp;·&nbsp; Privacy First
      </p>

      <!-- Headline -->
      <h1
        class="font-display text-parchment leading-[1.05] m-0"
        style="font-size: clamp(2.4rem, 5vw, 3.75rem); font-weight: 400;"
      >
        Your <em class="text-gold not-italic">Knowledge</em>
        <br />Companion
      </h1>

      <!-- Body -->
      <p
        class="font-body text-parchment-dim text-base md:text-lg leading-relaxed m-0 max-w-lg"
      >
        Collect, organise, and act on insights from books, blogs, and podcasts.
        Open Citadel helps you turn what you read and hear into decisions,
        ideas, and progress.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 items-center mt-2">
        <!-- Primary: Android download -->
        <a
          href="https://cloudreve.cr8-xyz.art/s/bdTk"
          target="_blank"
          rel="noopener noreferrer"
          id="download"
          class="inline-flex items-center gap-3 px-6 py-3.5 font-display text-sm font-semibold text-ink no-underline hover:opacity-90 transition-opacity"
          style="background: linear-gradient(135deg, #f2ca50, #d4af37);"
        >
          <!-- Android brand icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            preserveAspectRatio="xMidYMid"
            viewBox="0 0 256 150"
            width="18"
            height="18"
            aria-hidden="true"
            ><path
              fill="currentColor"
              d="M255.285 143.47c-.084-.524-.164-1.042-.251-1.56a128.119 128.119 0 0 0-12.794-38.288 128.778 128.778 0 0 0-23.45-31.86 129.166 129.166 0 0 0-22.713-18.005c.049-.08.09-.168.14-.25 2.582-4.461 5.172-8.917 7.755-13.38l7.576-13.068c1.818-3.126 3.632-6.26 5.438-9.386a11.776 11.776 0 0 0 .662-10.484 11.668 11.668 0 0 0-4.823-5.536 11.85 11.85 0 0 0-5.004-1.61 11.963 11.963 0 0 0-2.218.018 11.738 11.738 0 0 0-8.968 5.798c-1.814 3.127-3.628 6.26-5.438 9.386l-7.576 13.069c-2.583 4.462-5.173 8.918-7.755 13.38-.282.487-.567.973-.848 1.467-.392-.157-.78-.313-1.172-.462-14.24-5.43-29.688-8.4-45.836-8.4-.442 0-.879 0-1.324.006-14.357.143-28.152 2.64-41.022 7.12a119.434 119.434 0 0 0-4.42 1.642c-.262-.455-.532-.911-.79-1.367-2.583-4.462-5.173-8.918-7.755-13.38L65.123 15.25c-1.818-3.126-3.632-6.259-5.439-9.386A11.736 11.736 0 0 0 48.5.048 11.71 11.71 0 0 0 43.49 1.66a11.716 11.716 0 0 0-4.077 4.063c-.281.474-.532.967-.742 1.473a11.808 11.808 0 0 0-.365 8.188c.259.786.594 1.554 1.023 2.296a3973.32 3973.32 0 0 1 5.439 9.386c2.53 4.357 5.054 8.713 7.58 13.069 2.582 4.462 5.168 8.918 7.75 13.38.02.038.046.075.065.112A129.184 129.184 0 0 0 45.32 64.38a129.693 129.693 0 0 0-22.2 24.015 127.737 127.737 0 0 0-9.34 15.24 128.238 128.238 0 0 0-10.843 28.764 130.743 130.743 0 0 0-1.951 9.524c-.087.518-.167 1.042-.247 1.56A124.978 124.978 0 0 0 0 149.118h256c-.205-1.891-.449-3.77-.734-5.636l.019-.012Z"
            ></path></svg
          >
          Download for Android
        </a>

        <!-- Tertiary: iOS waitlist -->
        <a
          href="mailto:thamsanqa.dev@gmail.com?subject=iOS%20Waitlist%20-%20Notify%20Me&body=Hi%2C%20I%27d%20like%20to%20be%20notified%20when%20Open%20Citadel%20is%20available%20on%20iOS."
          class="inline-flex items-center gap-2 px-2 py-3.5 font-body text-sm font-medium text-gold no-underline hover:text-gold-deep transition-colors"
        >
          The Apple Waitlist
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="square"
            stroke-linejoin="miter"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Preview badge -->
      <p
        class="font-body text-xs text-gold uppercase tracking-[0.1em] m-0 self-start px-3 py-1.5"
        style="border: 1px solid var(--color-gold);"
      >
        Currently in Preview
      </p>
    </div>

    <!-- Right: Phone visual -->
    <div
      class="hidden md:flex justify-center items-end relative"
      style="min-height: 560px;"
    >
      <img
        class="phone-dark"
        src={library1Light.src}
        alt="Open Citadel app on Android"
        style="height: 560px; width: auto; object-fit: contain;"
      />
      <img
        class="phone-light"
        src={library1Dark.src}
        alt="Open Citadel app on Android"
        style="height: 560px; width: auto; object-fit: contain;"
      />
    </div>
  </div>
</section>
