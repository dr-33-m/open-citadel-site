---
// Nav — sticky, glass effect, sharp edges
---

<nav
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-12 py-4"
  style="background: var(--nav-bg); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);"
>
  <!-- Wordmark -->
  <a
    href="/"
    class="flex items-center gap-1 no-underline"
    aria-label="Open Citadel home"
  >
    <img src="/app-icon.png" alt="Open Citadel logo" class="h-12 w-12" />
    <span
      class="font-display text-gold text-lg font-medium tracking-tight leading-none"
    >
      Open Citadel
    </span>
  </a>

  <!-- Desktop nav links -->
  <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
    {
      [
        { label: "Timeline", href: "#timeline" },
        { label: "Library", href: "#library" },
        { label: "Reader", href: "#reader" },
        { label: "Samwell", href: "#samwell" },
      ].map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-body text-parchment text-sm uppercase tracking-[0.08em] hover:text-gold transition-colors duration-200 no-underline"
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Right: theme toggle + CTA -->
  <div class="hidden md:flex items-center gap-3">
    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      class="flex items-center justify-center w-9 h-9 text-parchment hover:text-gold transition-colors duration-200"
      aria-label="Toggle light/dark theme"
    >
      <!-- Sun icon (shown in dark mode → click to go light) -->
      <svg
        class="icon-sun"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="square"
        stroke-linejoin="miter"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="5"></circle><line
          x1="12"
          y1="1"
          x2="12"
          y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line
          x1="4.22"
          y1="4.22"
          x2="5.64"
          y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
        ></line><line x1="1" y1="12" x2="3" y2="12"></line><line
          x1="21"
          y1="12"
          x2="23"
          y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
        ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <!-- Moon icon (shown in light mode → click to go dark) -->
      <svg
        class="icon-moon"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="square"
        stroke-linejoin="miter"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>

    <!-- CTA -->
    <a
      href="https://cloudreve.cr8-xyz.art/s/bdTk"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-5 py-2.5 font-display text-sm font-semibold text-ink no-underline transition-opacity duration-200 hover:opacity-90"
      style="background: linear-gradient(135deg, #f2ca50, #d4af37);"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        preserveAspectRatio="xMidYMid"
        viewBox="0 0 256 150"
        width="18"
        height="18"
        aria-hidden="true"
        ><path
          fill="currentColor"
          d="M255.285 143.47c-.084-.524-.164-1.042-.251-1.56a128.119 128.119 0 0 0-12.794-38.288 128.778 128.778 0 0 0-23.45-31.86 129.166 129.166 0 0 0-22.713-18.005c.049-.08.09-.168.14-.25 2.582-4.461 5.172-8.917 7.755-13.38l7.576-13.068c1.818-3.126 3.632-6.26 5.438-9.386a11.776 11.776 0 0 0 .662-10.484 11.668 11.668 0 0 0-4.823-5.536 11.85 11.85 0 0 0-5.004-1.61 11.963 11.963 0 0 0-2.218.018 11.738 11.738 0 0 0-8.968 5.798c-1.814 3.127-3.628 6.26-5.438 9.386l-7.576 13.069c-2.583 4.462-5.173 8.918-7.755 13.38-.282.487-.567.973-.848 1.467-.392-.157-.78-.313-1.172-.462-14.24-5.43-29.688-8.4-45.836-8.4-.442 0-.879 0-1.324.006-14.357.143-28.152 2.64-41.022 7.12a119.434 119.434 0 0 0-4.42 1.642c-.262-.455-.532-.911-.79-1.367-2.583-4.462-5.173-8.918-7.755-13.38L65.123 15.25c-1.818-3.126-3.632-6.259-5.439-9.386A11.736 11.736 0 0 0 48.5.048 11.71 11.71 0 0 0 43.49 1.66a11.716 11.716 0 0 0-4.077 4.063c-.281.474-.532.967-.742 1.473a11.808 11.808 0 0 0-.365 8.188c.259.786.594 1.554 1.023 2.296a3973.32 3973.32 0 0 1 5.439 9.386c2.53 4.357 5.054 8.713 7.58 13.069 2.582 4.462 5.168 8.918 7.75 13.38.02.038.046.075.065.112A129.184 129.184 0 0 0 45.32 64.38a129.693 129.693 0 0 0-22.2 24.015 127.737 127.737 0 0 0-9.34 15.24 128.238 128.238 0 0 0-10.843 28.764 130.743 130.743 0 0 0-1.951 9.524c-.087.518-.167 1.042-.247 1.56A124.978 124.978 0 0 0 0 149.118h256c-.205-1.891-.449-3.77-.734-5.636l.019-.012Z"
        ></path></svg
      >
      Download Open Citadel
    </a>
  </div>

  <!-- Mobile menu trigger (hamburger) -->
  <button
    id="mobile-menu-btn"
    class="md:hidden flex flex-col gap-1.5 p-2 text-parchment"
    aria-label="Toggle menu"
  >
    <span class="block w-6 h-px bg-parchment"></span>
    <span class="block w-6 h-px bg-parchment"></span>
    <span class="block w-4 h-px bg-parchment"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden flex-col justify-center items-start px-8 pt-20"
  style="background: var(--nav-bg); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);"
>
  <ul class="list-none m-0 p-0 flex flex-col gap-6 w-full">
    {
      [
        { label: "Timeline", href: "#timeline" },
        { label: "Library", href: "#library" },
        { label: "Reader", href: "#reader" },
        { label: "Samwell", href: "#samwell" },
      ].map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-display text-parchment text-3xl font-light hover:text-gold transition-colors duration-200 no-underline mobile-nav-link"
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
  <a
    href="https://cloudreve.cr8-xyz.art/s/bdTk"
    target="_blank"
    rel="noopener noreferrer"
    class="mt-10 inline-flex items-center gap-2 px-6 py-3 font-display text-sm font-semibold text-ink no-underline mobile-nav-link"
    style="background: linear-gradient(135deg, #f2ca50, #d4af37);"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid"
      viewBox="0 0 256 150"
      width="18"
      height="18"
      aria-hidden="true"
      ><path
        fill="currentColor"
        d="M255.285 143.47c-.084-.524-.164-1.042-.251-1.56a128.119 128.119 0 0 0-12.794-38.288 128.778 128.778 0 0 0-23.45-31.86 129.166 129.166 0 0 0-22.713-18.005c.049-.08.09-.168.14-.25 2.582-4.461 5.172-8.917 7.755-13.38l7.576-13.068c1.818-3.126 3.632-6.26 5.438-9.386a11.776 11.776 0 0 0 .662-10.484 11.668 11.668 0 0 0-4.823-5.536 11.85 11.85 0 0 0-5.004-1.61 11.963 11.963 0 0 0-2.218.018 11.738 11.738 0 0 0-8.968 5.798c-1.814 3.127-3.628 6.26-5.438 9.386l-7.576 13.069c-2.583 4.462-5.173 8.918-7.755 13.38-.282.487-.567.973-.848 1.467-.392-.157-.78-.313-1.172-.462-14.24-5.43-29.688-8.4-45.836-8.4-.442 0-.879 0-1.324.006-14.357.143-28.152 2.64-41.022 7.12a119.434 119.434 0 0 0-4.42 1.642c-.262-.455-.532-.911-.79-1.367-2.583-4.462-5.173-8.918-7.755-13.38L65.123 15.25c-1.818-3.126-3.632-6.259-5.439-9.386A11.736 11.736 0 0 0 48.5.048 11.71 11.71 0 0 0 43.49 1.66a11.716 11.716 0 0 0-4.077 4.063c-.281.474-.532.967-.742 1.473a11.808 11.808 0 0 0-.365 8.188c.259.786.594 1.554 1.023 2.296a3973.32 3973.32 0 0 1 5.439 9.386c2.53 4.357 5.054 8.713 7.58 13.069 2.582 4.462 5.168 8.918 7.75 13.38.02.038.046.075.065.112A129.184 129.184 0 0 0 45.32 64.38a129.693 129.693 0 0 0-22.2 24.015 127.737 127.737 0 0 0-9.34 15.24 128.238 128.238 0 0 0-10.843 28.764 130.743 130.743 0 0 0-1.951 9.524c-.087.518-.167 1.042-.247 1.56A124.978 124.978 0 0 0 0 149.118h256c-.205-1.891-.449-3.77-.734-5.636l.019-.012Z"
      ></path></svg
    >
    Download Open Citadel
  </a>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("flex");
    if (isOpen) {
      menu?.classList.remove("flex");
      menu?.classList.add("hidden");
    } else {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
    }
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.remove("flex");
      menu?.classList.add("hidden");
    });
  });

  // Theme toggle
  const toggle = document.getElementById("theme-toggle");
  const html = document.documentElement;

  toggle?.addEventListener("click", () => {
    const isLight = html.getAttribute("data-theme") === "light";
    if (isLight) {
      html.removeAttribute("data-theme");
      localStorage.setItem("oc-theme", "dark");
    } else {
      html.setAttribute("data-theme", "light");
      localStorage.setItem("oc-theme", "light");
    }
  });
</script>
